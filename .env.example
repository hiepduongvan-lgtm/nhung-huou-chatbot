# ====================================================================
# FILE CẤU HÌNH — Đổi tên file này thành ".env" rồi điền giá trị thật vào
# ====================================================================

# 1. API key của Claude (Anthropic). Lấy tại: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-dien-key-cua-ban-vao-day

# (Tùy chọn) Model AI. Mặc định Haiku (rẻ, nhanh).
# Muốn câu trả lời cao cấp hơn -> claude-opus-4-8
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 2. Token của Fanpage Facebook (Page Access Token).
#    Lấy trong Facebook Developer (xem HUONG_DAN.md, Bước 7).
PAGE_ACCESS_TOKEN=dien-page-access-token-vao-day

# 3. Mật khẩu tự đặt để nối webhook (bạn tự nghĩ ra 1 chuỗi bất kỳ,
#    rồi dán đúng chuỗi này khi cấu hình webhook trên Facebook).
VERIFY_TOKEN=nhunghuouboda2026

# 4. Số lần bot trả lời comment CÔNG KHAI trước khi chuyển sang nhắn tin riêng.
#    Mặc định 2 -> đến comment thứ 3 của cùng 1 khách thì bot inbox.
SO_TANG_CONG_KHAI=2

# ====================================================================
# 5. GOOGLE SHEET — lưu khách hàng tự động (TÙY CHỌN, xem HUONG_DAN.md)
#    Nếu để trống, hệ thống vẫn lưu khách vào file khach_hang.csv.
# ====================================================================
# ID của Google Sheet (lấy từ URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=
# Tên file credentials tải từ Google Cloud (đặt cùng thư mục dự án)
GOOGLE_CREDENTIALS_FILE=google_credentials.json
# Tên tab/sheet để ghi khách (mặc định: Khách Chatbot FB)
GOOGLE_SHEET_TAB=Khách Chatbot FB

# ====================================================================
# 6. THEO ĐUỔI KHÁCH HÀNG TỰ ĐỘNG
# ====================================================================
FOLLOWUP_GIO_CHO=24      # số giờ chờ trước khi nhắn theo đuổi (mặc định 24h)
FOLLOWUP_TOI_DA=3        # số lần theo đuổi tối đa mỗi khách (để trống = không giới hạn)
